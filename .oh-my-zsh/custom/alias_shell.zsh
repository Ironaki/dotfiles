#1. cd
alias cdd="cd ~/Dropbox/Programming/"
alias cv="cd .."
alias cvv="cd ../.."
alias cvvv="cd ../../.."
alias drop="cd ~/Dropbox"
alias dl="cd ~/Downloads"
alias org="cd ~/Dropbox/Org"
alias guitar="cd ~/Dropbox/Guitar/Guitar-Video"

#2. Builtin Tools
alias ll="ls -alhFG"
alias la="ls -aG"
alias ff="open ."
alias tt="type"
alias rm="rm -i"
alias bash="bash -l"
alias -g gg="| grep  --color=auto --exclude-dir={.bzr,CVS,.git,.hg,.svn}"
alias copy="pbcopy"
alias dus="du -sh"

#c installed tools alias
alias pa="realpath"
alias x="/Applications/Emacs.app/Contents/MacOS/Emacs -nw"
alias xs="/Applications/Emacs.app/Contents/MacOS/Emacs"
